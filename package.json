    "react": "^16.12.0",
    "react-app-rewire-hot-loader": "^2.0.1",
    "react-app-rewired": "^2.1.6",
    "react-bootstrap": "^1.2.2",
    "react-dom": "^16.12.0",
    "react-hot-loader": "^4.12.21",
    "react-leaflet": "^2.7.0",
    "react-redux": "^7.1.3",
    "react-scripts": "3.4.1",
