    "@testing-library/user-event": "^12.6.0",
    "@types/jest": "^26.0.19",
    "@types/leaflet": "^1.5.19",
    "@types/node": "^14.14.14",
    "@types/react": "^17.0.0",
    "@types/react-dom": "^17.0.0",
    "@types/react-leaflet": "^2.5.2",
    "@types/react-redux": "^7.1.12",
    "@typescript-eslint/eslint-plugin": "^4.11.0",
